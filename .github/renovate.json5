{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:best-practices',
    ':semanticCommits',
  ],
  schedule: [
    'at any time',
  ],
  baseBranchPatterns: [
    'main',
    'release-v2.8',
    'release-v2.9',
    'release-v2.10',
    '/^release-v3.*/',
  ],
  vulnerabilityAlerts: {
    enabled: true,
    labels: [
      'security',
    ],
  },
  osvVulnerabilityAlerts: true,
  prConcurrentLimit: 20,
  branchConcurrentLimit: 20,
  ignoreDeps: [],
  separateMajorMinor: true,
  automergeStrategy: 'squash',
  automergeType: 'pr',
  automerge: true,
  platformAutomerge: true,
  addLabels: [
    'dependencies',
    'renovate',
    '{{manager}}',
    '{{updateType}}',
  ],
  minimumReleaseAge: '7 days',
  postUpdateOptions: [
    'gomodUpdateImportPaths',
    'gomodTidy',
    'gomodVendor',
  ],
  customManagers: [
    {
      description: 'Update tempo-ci-tools image tag in Makefile and build/tools.mk',
      customType: 'regex',
      managerFilePatterns: ['/^Makefile$/', '/^build\\/tools\\.mk$/'],
      matchStrings: [
        'TEMPO_CI_TOOLS_IMAGE\\s*\\?=\\s*(?<depName>grafana/tempo-ci-tools):(?<currentValue>main-[0-9a-f]{7}-\\d{8}-\\d{6})(?:@(?<currentDigest>sha256:[a-f0-9]+))?',
        'TOOLS_IMAGE_TAG\\s*\\?=\\s*(?<currentValue>main-[0-9a-f]{7}-\\d{8}-\\d{6})',
      ],
      depNameTemplate: 'grafana/tempo-ci-tools',
      datasourceTemplate: 'docker',
    },
  ],
  packageRules: [
    {
      description: 'Disable all non-vulnerability updates for releases',
      matchBaseBranches: [
        '/^release-v.*/',
      ],
      matchPackageNames: [
        '*',
      ],
      enabled: false,
    },
    {
      description: 'Allow Go and CI tools image updates on release branches to be up2date on CVE',
      matchBaseBranches: [
        '/^release-v.*/',
      ],
      matchDepNames: ['go', 'golang', 'grafana/tempo-ci-tools'],
      enabled: true,
    },
    {
      description: 'Group OpenTelemetry OTEL updates',
      matchManagers: [
        'gomod',
      ],
      groupName: 'opentelemetry-otel',
      matchPackageNames: [
        'go.opentelemetry.io/otel{,/**}',
      ],
    },
    {
      description: 'Group OpenTelemetry Contrib updates',
      matchManagers: [
        'gomod',
      ],
      groupName: 'opentelemetry-contrib',
      matchPackageNames: [
        'go.opentelemetry.io/contrib{,/**}',
        'github.com/open-telemetry/opentelemetry-collector-contrib{,/**}',
      ],
    },
    {
      description: 'Group OpenTelemetry Collector updates',
      matchManagers: [
        'gomod',
      ],
      groupName: 'opentelemetry-collector',
      matchPackageNames: [
        'go.opentelemetry.io/collector{,/**}',
      ],
    },
    {
      description: 'Group k8s.io updates',
      matchManagers: [
        'gomod',
      ],
      groupName: 'k8s.io',
      matchPackageNames: [
        'k8s.io{,/**}',
      ],
    },
    {
      description: 'Group Docker updates',
      matchManagers: [
        'dockerfile',
      ],
      groupName: 'docker',
    },
    {
      description: 'Fast-track Go updates: bump go directive and skip release age for Go images',
      matchDepNames: ['go', 'golang'],
      rangeStrategy: 'bump',
      minimumReleaseAge: '0 days',
    },
    {
      description: 'Use regex versioning for tempo-ci-tools (branch-sha-datetime tags)',
      matchManagers: [
        'custom.regex',
      ],
      matchPackageNames: [
        'grafana/tempo-ci-tools',
      ],
      groupName: 'tempo-ci-tools',
      versioning: 'regex:^main-[0-9a-f]{7}-(?<major>\\d{8})-(?<patch>\\d{6})$',
      minimumReleaseAge: '0 days',
    },
  ],
}
