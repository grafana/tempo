      "type": "prometheus",
      "uid": "$ds"
     },
     "expr": "label_replace(label_replace(label_join(traces_service_graph_connection_info{cluster=~\"$cluster\", namespace=~\"$namespace\", client_service_namespace=~\"$client_namespace\", server_service_namespace=~\"$server_namespace\"}, \"id\", \"->\", \"client\", \"server\"), \"source\", \"$1\", \"client\", \"(.*)\"), \"target\", \"$1\", \"server\", \"(.*)\")",
